{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debugger: current file",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "env": {
                "PYTHONUNBUFFERED": "1",
                "PYTHONPATH": "${workspaceFolder}",
                "PYARROW_IGNORE_TIMEZONE": "1",
                "DATABRICKS_HOST": "https://<your-workspace>.cloud.databricks.com",
                "DATABRICKS_TOKEN": "",
                "DATABRICKS_CLUSTER_ID": ""
            },
            "justMyCode": false
        }
    ]
}
